    "url": "https://github.com/energiamEcoTouch/node-red-dashboard-2-insight-energiam.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "ui-insight": "nodes/ui-insight.js"
    }
  },
  "node-red-dashboard-2": {
